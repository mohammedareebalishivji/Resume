{
  "name": "areeb-shivji-portfolio",
  "version": "2.0.0",
  "description": "Premium portfolio for Mohammed Areeb Ali Shivji",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch server.js",
    "start": "node server.js",
    "build:css": "sass scss/style.scss public/css/style.css --style compressed",
    "watch:css": "sass --watch scss/style.scss public/css/style.css",
    "build": "npm run build:css",
    "setup": "npm install && npm run build"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "nodemailer": "^6.10.0"
  },
  "devDependencies": {
    "sass": "^1.86.3"
  }
}
